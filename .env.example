# Database Configuration
# Choose ONE of the following options:

# Option 1: Use included PostgreSQL container (default for Docker Compose)
DATABASE_URL=postgresql://postgres:your_secure_password_here@postgres:5432/metadata_db
POSTGRES_PASSWORD=your_secure_password_here

# Option 2: Use external database (e.g., Neon, AWS RDS, your own PostgreSQL server)
# DATABASE_URL=postgresql://username:password@host.region.provider.tech/dbname?sslmode=require
# Note: When using external database, you can remove POSTGRES_PASSWORD and the postgres service from docker-compose.yml

# Session Secret (generate a secure random string - minimum 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your_secure_session_secret_minimum_32_characters

# Secure Cookies (set to 'true' only when using HTTPS in production)
# For local testing without HTTPS, leave this unset or set to 'false'
SECURE_COOKIES=false

# Google OAuth (Optional - leave empty to disable Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Node Environment
NODE_ENV=production
